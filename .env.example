AGENTIC_IGV_DEBUG="0"

# LLM Backend Configuration
# Supported backends: "openai" or "bedrock"
LLM_BACKEND="openai"

# OpenAI Configuration (required when LLM_BACKEND="openai")
OPENAI_API_KEY=""
BASE_URL="https://api.openai.com/v1"
LANGGRAPH_MODEL="gpt-4o-mini"

# LLM Common Settings (applies to both backends)
LLM_TEMPERATURE="0"
LLM_MAX_TOKENS="2048"

# AWS Bedrock Configuration (required when LLM_BACKEND="bedrock")
# AWS_ACCESS_KEY_ID and AWS_SECRET_ACCESS_KEY can be omitted if using boto3's default credential chain
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID=""
# Bedrock model ID, e.g. "anthropic.claude-3-sonnet-20240229-v1:0"
AWS_BEDROCK_MODEL=""